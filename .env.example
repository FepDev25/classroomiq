# === PostgreSQL (servicio db de docker-compose) ===
POSTGRES_DB=classroomiq
POSTGRES_USER=classroomiq
POSTGRES_PASSWORD=classroomiq
POSTGRES_PORT=5436

# === Datasource del backend ===
DB_URL=jdbc:postgresql://localhost:5436/classroomiq
DB_USERNAME=classroomiq
DB_PASSWORD=classroomiq

# === JWT ===
JWT_SECRET=dev-only-secret-change-me-please-32bytes-minimum-aaaaaaaa

# === Embeddings ===
# columna vector(N) del esquema,  bge-m3 - 1024.
EMBEDDINGS_PROVIDER=ollama
EMBEDDINGS_DIMENSION=1024
# Si es true, al arrancar se contacta a Ollama y se valida la dimensión real (fail-fast).
EMBEDDINGS_VERIFY_ON_STARTUP=false
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBED_MODEL=bge-m3
OLLAMA_TIMEOUT=PT30S
OLLAMA_EMBED_BATCH=16

# === LLM ===
ANTHROPIC_API_KEY=sk-ant-...

# === Almacenamiento de archivos de entregas ===
# Directorio raíz local, los archivos son sensibles y no salen del servidor.
STORAGE_BASE_PATH=./var/entregas
UPLOAD_MAX_FILE_SIZE=50MB
UPLOAD_MAX_REQUEST_SIZE=200MB
