# === PostgreSQL (servicio db de docker-compose) ===
POSTGRES_DB=classroomiq
POSTGRES_USER=classroomiq
POSTGRES_PASSWORD=classroomiq
POSTGRES_PORT=5436

# === Datasource del backend ===
DB_URL=jdbc:postgresql://localhost:5436/classroomiq
DB_USERNAME=classroomiq
DB_PASSWORD=classroomiq

# === Perfil de Spring ===
# Dejar vacío en desarrollo (perfil default). En el servidor: prod (exige las vars sin defaults).
# SPRING_PROFILES_ACTIVE=prod

# === JWT ===
JWT_SECRET=dev-only-secret-change-me-please-32bytes-minimum-aaaaaaaa

# === Embeddings ===
# columna vector(N) del esquema,  bge-m3 - 1024.
EMBEDDINGS_PROVIDER=ollama
EMBEDDINGS_DIMENSION=1024
# Si es true, al arrancar se contacta a Ollama y se valida la dimensión real (fail-fast).
EMBEDDINGS_VERIFY_ON_STARTUP=false
# Ollama corriendo en el host (por defecto). Si se levanta el servicio 'ollama' de docker-compose
# (perfil --profile ollama) y el backend también es contenedor, usar http://ollama:11434.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBED_MODEL=bge-m3
OLLAMA_TIMEOUT=PT30S
OLLAMA_EMBED_BATCH=16

# === Chunking del texto antes de generar embeddings ===
# Presupuesto en caracteres (~4 chars/token): 2000 ≈ 500 tokens, con 300 de solape (~15%).
CHUNK_MAX_CHARS=2000
CHUNK_OVERLAP_CHARS=300

# === LLM (motor de evaluación, Fase 4) ===
# Proveedor intercambiable; por ahora Anthropic cloud.
ANTHROPIC_API_KEY=sk-ant-...
LLM_PROVIDER=anthropic
# Estrategia dos niveles: potente para el análisis por criterio, económico para tareas simples.
LLM_MODELO_POTENTE=claude-sonnet-4-6
LLM_MODELO_ECONOMICO=claude-haiku-4-5
LLM_MAX_TOKENS=8000
# Esfuerzo del tier potente (low|medium|high|max) no aplica al económico (Haiku).
LLM_EFFORT=high
# Si es true, al arrancar se hace una llamada sonda al proveedor (fail-fast de API key).
LLM_VERIFY_ON_STARTUP=false

# === Retrieval / evaluación ===
# Fragmentos relevantes que se recuperan por criterio (RAG) para armar el prompt del LLM.
# Más alto = más contexto pero más tokens de entrada por llamada.
EVAL_RETRIEVAL_TOPK=8

# === Similitud entre entregas ===
# Umbral de "similitud alta" por defecto (0..1) si el docente no especifica al generar el reporte.
SIMILITUD_UMBRAL_DEFAULT=0.75
# Pares de fragmentos de mayor similitud que se guardan por par para la vista lado a lado.
SIMILITUD_TOP_FRAGMENTOS=5

# === Almacenamiento de archivos de entregas ===
# Directorio raíz local, los archivos son sensibles y no salen del servidor.
STORAGE_BASE_PATH=./var/entregas
UPLOAD_MAX_FILE_SIZE=50MB
UPLOAD_MAX_REQUEST_SIZE=200MB
